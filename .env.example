# Basic Memory Environment Variables Example
# Copy this file to .env and customize as needed
# Note: .env files are gitignored and should never be committed

# ============================================================================
# Database Configuration
# ============================================================================
# MemoryHub currently supports SQLite only.

# BASIC_MEMORY_DATABASE_BACKEND=sqlite
# BASIC_MEMORY_DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/memory.db
